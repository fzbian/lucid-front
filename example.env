# URL base del backend API (obligatorio)
# Ejemplo local:
# API_BASE=http://localhost:8080
API_BASE=API_BASE

# Puerto del servidor frontend de produccion (opcional)
# PORT=8082
PORT=8082

# Opcional: fuerza base API directa para el cliente en /config.json
# Si no se define, el frontend usa el proxy local /api.
# CLIENT_API_BASE=https://api.midominio.com
CLIENT_API_BASE=
